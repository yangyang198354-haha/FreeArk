# FreeArk 大屏心跳抓取脚本凭据模板
# 用法：
#   复制本文件为 .env.capture（与本文件同目录）
#   cp .env.capture.template .env.capture
#   编辑 .env.capture，填入实际凭据
#
# .env.capture 已被 .gitignore 排除，不会提交到版本库

# MQTT Broker 用户名
MQTT_USERNAME=admin

# MQTT Broker 密码
MQTT_PASSWORD=public

# 可选：指定输出文件路径（默认：脚本目录下的 capture_raw_3-1-702.jsonl）
# CAPTURE_OUTPUT=C:\path\to\custom_output.jsonl
